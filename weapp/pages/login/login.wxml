<view class="container">
  <view class="form-container">
    <input 
      class="input-field" 
      placeholder="请输入账户名" 
      value="{{ formData.username }}"
      bindinput="onUsernameInput"
    />
    <input 
      class="input-field" 
      type="password"
      placeholder="请输入密码" 
      value="{{ formData.password }}"
      bindinput="onPasswordInput"
    />
    <button class="login-btn" bindtap="handleLogin">登录</button>
  </view>
</view>