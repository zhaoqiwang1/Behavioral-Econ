.container {
    padding: 40rpx;
    min-height: 100vh;
    background-color: #f5f5f5;
  }
  
  .form-container {
    margin-top: 200rpx;
  }
  
  .input-field {
    width: 100%;
    height: 80rpx;
    margin-bottom: 40rpx;
    padding: 0 20rpx;
    box-sizing: border-box;
    background-color: white;
    border-radius: 10rpx;
    font-size: 32rpx;
  }
  
  .login-btn {
    width: 100%;
    height: 80rpx;
    background-color: #007aff;
    color: white;
    border-radius: 10rpx;
    font-size: 32rpx;
    line-height: 80rpx;
  }