/* 与登录页保持一致 */
.container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    background-color: #f5f5f5;
    padding: 40rpx;
  }
  
  .form-container {
    width: 100%;
    max-width: 600rpx;
    background: white;
    padding: 60rpx 40rpx;
    border-radius: 20rpx;
    box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.1);
  }
  
  .input-field {
    width: 100%;
    height: 80rpx;
    border: 1px solid #ddd;
    border-radius: 10rpx;
    padding: 0 20rpx;
    margin-bottom: 30rpx;
    font-size: 30rpx;
    box-sizing: border-box;
  }
  
  /* picker 显示样式 */
  .picker-display {
    width: 100%;
    height: 80rpx;
    border: 1px solid #ddd;
    border-radius: 10rpx;
    padding: 0 20rpx;
    margin-bottom: 30rpx;
    font-size: 30rpx;
    line-height: 80rpx;
    color: #333;
    box-sizing: border-box;
    background: white;
  }
  
  /* 分组标题 */
  .section-title {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
    margin: 20rpx 0 30rpx 0;
    padding-bottom: 10rpx;
    border-bottom: 2rpx solid #eee;
  }
  
  .register-btn {
    width: 100%;
    height: 88rpx;
    background: #007aff;
    color: white;
    border-radius: 44rpx;
    font-size: 34rpx;
    font-weight: 600;
    margin-top: 20rpx;
    border: none;
  }
  
  .register-btn:active {
    opacity: 0.8;
  }
  
  .login-link {
    margin-top: 30rpx;
    color: #007aff;
    text-align: center;
    font-size: 28rpx;
    text-decoration: underline;
  }