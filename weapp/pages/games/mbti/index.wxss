.container {
    padding: 40rpx;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-height: 100vh;
    background: #f5f7fa;
  }
  
  .header {
    text-align: center;
    margin-bottom: 60rpx;
  }
  .title {
    font-size: 44rpx;
    font-weight: bold;
    display: block;
    color: #333;
  }
  .desc {
    font-size: 30rpx;
    color: #666;
    margin-top: 16rpx;
  }
  
  .input-area {
    width: 80%;
    margin-bottom: 40rpx;
  }
  .input-area input {
    width: 100%;
    height: 80rpx;
    border: 2rpx solid #ddd;
    border-radius: 16rpx;
    padding: 0 20rpx;
    font-size: 36rpx;
    text-align: center;
    background: #fff;
  }
  .input-area input:disabled {
    background: #f0f0f0;
  }
  
  .submit-btn {
    width: 60%;
    height: 80rpx;
    line-height: 80rpx;
    background: #165DFF;
    color: #fff;
    border-radius: 40rpx;
    font-size: 32rpx;
  }
  .submit-btn[disabled] {
    background: #ccc;
  }
  
  .completed {
    margin-top: 60rpx;
    padding: 40rpx;
    background: #e8f5e9;
    border-radius: 20rpx;
    font-size: 36rpx;
    color: #2e7d32;
    text-align: center;
    width: 80%;
  }