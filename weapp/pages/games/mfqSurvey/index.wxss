.container {
    padding: 24rpx;
    background-color: #f8f9fa;
    min-height: 100vh;
    box-sizing: border-box;
  }
  
  /* 加载 & 完成状态 */
  .loading, .completed-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding-top: 200rpx;
  }
  .completed-icon { font-size: 80rpx; margin-bottom: 20rpx; }
  .completed-title { font-size: 36rpx; font-weight: bold; color: #333; margin-bottom: 12rpx; }
  .completed-desc { font-size: 28rpx; color: #666; }
  .loading text { font-size: 28rpx; color: #666; }
  
  /* 部分标题 */
  .section-title {
    background-color: #e3f2fd;
    border-radius: 12rpx;
    padding: 24rpx;
    margin-bottom: 24rpx;
  }
  .section-title .title {
    display: block;
    font-weight: bold;
    font-size: 32rpx;
    color: #1976d2;
    margin-bottom: 12rpx;
  }
  .section-title .desc {
    display: block;
    font-size: 26rpx;
    color: #333;
    line-height: 1.6;
    margin-bottom: 12rpx;
  }
  .section-title .label {
    display: block;
    font-size: 24rpx;
    color: #555;
    margin-bottom: 8rpx;
  }
  .scale-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8rpx 20rpx;
  }
  .scale-list text {
    font-size: 22rpx;
    color: #666;
  }
  
  /* 问题卡片 */
  .question-card {
    background-color: #fff;
    border-radius: 12rpx;
    padding: 24rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  }
  .q-text {
    display: block;
    font-size: 28rpx;
    line-height: 1.6;
    color: #333;
    margin-bottom: 20rpx;
  }
  
  /* 选项组 - 使用 grid 布局确保整齐 */
  .radio-group {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16rpx;
  }
  
  /* 单个选项 */
  .radio-label {
    display: flex;
    align-items: center;
    padding: 16rpx 20rpx;
    border: 2rpx solid #e0e0e0;
    border-radius: 8rpx;
    transition: all 0.2s ease;
    position: relative;
  }
  
  /* 选中态 */
  .radio-label.active {
    border-color: #1976d2;
    background-color: #e3f2fd;
  }
  .radio-label.active text {
    color: #1976d2;
    font-weight: 500;
  }
  
  /* 隐藏原生 radio，保留点击热区 */
  .radio-label radio {
    position: absolute;
    opacity: 0;
    width: 100%;
    height: 100%;
    left: 0;
    top: 0;
    z-index: 1;
  }
  
  /* 自定义圆圈指示器 */
  .radio-label::before {
    content: '';
    width: 32rpx;
    height: 32rpx;
    border: 2rpx solid #bbb;
    border-radius: 50%;
    margin-right: 12rpx;
    flex-shrink: 0;
    transition: all 0.2s ease;
  }
  .radio-label.active::before {
    border-color: #1976d2;
    background-color: #1976d2;
    box-shadow: inset 0 0 0 4rpx #fff;
  }
  
  .radio-label text {
    font-size: 24rpx;
    color: #555;
    line-height: 1.4;
  }
  
  /* 提交按钮 */
  .submit-btn {
    width: 100% !important;
    margin-top: 40rpx;
    background-color: #1976d2 !important;
    color: #fff !important;
    font-size: 32rpx;
    border-radius: 12rpx;
    padding: 24rpx 0;
    border: none;
  }
  .submit-btn[disabled] {
    background-color: #ccc !important;
    color: #999 !important;
  }