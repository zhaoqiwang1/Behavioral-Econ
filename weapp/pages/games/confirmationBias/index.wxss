.container {
    padding: 20rpx;
    background: #f5f7fa;
    min-height: 100vh;
  }
  
  /* 通用部分 */
  .section {
    margin-bottom: 30rpx;
  }
  .section-header {
    background: #e3f2fd;
    padding: 20rpx;
    border-radius: 16rpx;
    margin-bottom: 20rpx;
  }
  .phase-title {
    font-size: 36rpx;
    font-weight: bold;
    display: block;
    color: #1565C0;
  }
  .phase-desc {
    font-size: 28rpx;
    color: #333;
    display: block;
    margin-top: 8rpx;
  }
  .phase2-desc text {
    display: block;
    font-size: 26rpx;
    color: #555;
    line-height: 1.6;
  }
  
  .topic-card {
    background: #fff;
    border-radius: 16rpx;
    padding: 24rpx;
    margin-bottom: 24rpx;
    border: 1rpx solid #eee;
  }
  .topic-label {
    font-size: 32rpx;
    font-weight: bold;
    color: #165DFF;
    display: block;
    margin-bottom: 12rpx;
  }
  .topic-content {
    font-size: 28rpx;
    color: #333;
    line-height: 1.8;
    background: #f9f9f9;
    padding: 16rpx;
    border-radius: 8rpx;
    margin-bottom: 16rpx;
  }
  .topic-content text {
    display: block;
  }
  
  .question-row {
    margin-top: 12rpx;
  }
  .question-text {
    font-size: 30rpx;
    font-weight: 500;
    display: block;
    margin-bottom: 12rpx;
    color: #333;
  }
  .radio-label {
    display: inline-block;
    margin-right: 40rpx;
    font-size: 30rpx;
  }
  .radio-label radio {
    margin-right: 10rpx;
  }
  
  .sub-label {
    font-size: 28rpx;
    color: #555;
    display: block;
    margin: 12rpx 0;
  }
  .divider {
    height: 2rpx;
    background: #eee;
    margin: 16rpx 0;
  }
  .opinion-box {
    background: #f5f5f5;
    padding: 16rpx;
    border-radius: 8rpx;
    margin-bottom: 12rpx;
    border-left: 4rpx solid #165DFF;
  }
  .opinion-box .opinion-label {
    font-weight: bold;
    color: #165DFF;
  }
  .opinion-box text {
    font-size: 28rpx;
    line-height: 1.6;
    color: #333;
  }
  
  /* 评分行 */
  .rating-row {
    display: flex;
    align-items: center;
    margin: 12rpx 0;
    font-size: 28rpx;
  }
  .rating-row .bold {
    font-weight: bold;
    color: #165DFF;
  }
  .picker-display {
    border: 1rpx solid #ddd;
    border-radius: 8rpx;
    padding: 8rpx 24rpx;
    margin-left: 16rpx;
    background: #fff;
    font-size: 28rpx;
    min-width: 80rpx;
    text-align: center;
  }
  
  .tips-text {
    text-align: center;
    margin: 16rpx 0;
    font-size: 28rpx;
    color: #f44336;
    font-weight: bold;
  }
  
  .confirm-btn {
    width: 60%;
    height: 80rpx;
    line-height: 80rpx;
    background: #165DFF;
    color: #fff;
    border-radius: 40rpx;
    font-size: 32rpx;
    margin: 10rpx auto;
    display: block;
  }
  .confirm-btn[disabled] {
    background: #ccc;
  }
  
  .submit-btn {
    width: 80%;
    height: 80rpx;
    line-height: 80rpx;
    background: #165DFF;
    color: #fff;
    border-radius: 40rpx;
    font-size: 32rpx;
    margin: 20rpx auto;
    display: block;
  }
  .submit-btn[disabled] {
    background: #ccc;
  }
  
  .completed {
    margin-top: 40rpx;
    padding: 40rpx;
    background: #e8f5e9;
    border-radius: 20rpx;
    font-size: 36rpx;
    color: #2e7d32;
    text-align: center;
    width: 90%;
    margin-left: auto;
    margin-right: auto;
  }