  /* #region 其他 */
.resultBadge {
    position: absolute;
    top: 32rpx;
    right: 32rpx;
    background: rgba(255,255,255,0.2);
    backdrop-filter: blur(10rpx);
    padding: 16rpx 32rpx;
    border-radius: 40rpx;
    color: #fff;
    font-size: 18rpx;
    border: 1rpx solid rgba(255,255,255,0.3);
    }
    .comingSoon::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(120,127,128,0.8) 0%, rgba(189,195,199,0.3) 100%);
    }
  /* #endregion */

  /* 移动端适配 */
  @media screen and (max-width:750rpx) {
    .homeworkCardsWrap {
      padding: 40rpx;
    }
    .homeworkCard {
      width: calc((100% - 48rpx) / 2);
    }
    .gameBtn {
      width: 400rpx;
      height: 320rpx;
    }
    .scrollButton.left { left: -40rpx; }
    .scrollButton.right { right: -40rpx; }
  }
  