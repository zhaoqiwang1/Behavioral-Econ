/* 全局容器 */
.homepageContainer {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  .homepageContent {
    flex: 1;
    margin-top: 60rpx;
    width: 100%;
  }
  
  /* 顶部欢迎横幅 */
  .welcomeContainer {
    position: relative;
    width: 100%;
    margin: 0;
    padding: 0;
    left: 0;
    right: 0;
  }
  
  /* 背景图：铺满、无空白 */
  .welcomeBg {
    width: 100%;
    height: 50vh;          /* 改为 50vh，即屏幕高度的一半 */
    min-height: unset;     /* 去掉最小高度限制 */
    max-height: unset;     /* 去掉最大高度限制 */
    object-fit: cover;
    display: block;
    margin: 0;
    padding: 0; 
    border-radius: 0 !important;
  }
  
  /* 文字层 */
  .welcomeContent {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background: rgba(0, 0, 0, 0.3);
    color: white;
    text-align: center;
    padding: 0 30rpx;
    box-sizing: border-box;
  }
  
  .welcomeMessageTitle {
    font-size: 44rpx;
    color: #f5f5f5;
    font-weight: 500;
  }
  
  .welcomeMessageDescription {
    font-size: 28rpx;
    color: #81da76;
    line-height: 1.6;
  }
  
  .welcomeMessageHightlight {
    color: #dbfbe0;
  }

  .welcomeMessage {
    background-image: url('https://zhaoqiwangteaching-images.oss-cn-guangzhou.aliyuncs.com/hangzhou1.jpg');
    background-size: cover;
    background-position: center;
    background-color: rgba(0,0,0,0.1);
    background-blend-mode: overlay;
    margin-bottom: 200rpx;
    text-align: center;
    position: relative;
    min-height: 2000rpx;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 32rpx;
    color: #fff;
    padding: 0 40rpx;
  }
  .welcomeMessageTitle {
    font-weight: 500;
    font-size: 44rpx;
    color: #ffffff;
  }
  .welcomeMessageDescription {
    font-weight: 500;
    font-size: 24rpx;
    color: #25ff08;
    line-height: 1.8;
  }
  .welcomeMessageHightlight {
    color: #fafafa;
  }


 .syllabusBtn {
  position: absolute;
  max-width: 200rpx;
  left: 4%;
  bottom: 50rpx;
  padding: 14rpx 16rpx;
  font-size: 25rpx;
  background: #fff;
  color: #111;
  border: 1rpx solid #ddd;
  border-radius: 30rpx;
  font-weight: 500;
}

  /* #region Game section 分区标题 */
  .gameSectionTitle {
    width: 90%;
    margin-top: 20rpx;
    margin: 40rpx auto 32rpx;
    padding: 10rpx 20rpx;
  }

  .gameSectionTitle .title {
    display: block;
    font-size: 40rpx;
    font-weight: bold;
    margin-bottom: 16rpx;
  }
  .gameSectionTitle .desc {
    font-size: 26rpx;
    color: #666;
  }
  

  .gameGridContainer {
    position: relative;
    width: 100%;
  }
  .gameGrid {
    display: flex;
    flex-wrap: nowrap;
    padding: 32rpx;
    margin-bottom: 0rpx;
    box-sizing: border-box;
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .gameCardWrapper {
    flex-shrink: 0;        /* 防止卡片被压缩 */
    margin-right: 15rpx;   /* 在这里控制卡片之间的完美间隙 */
  }
  /* 隐藏滚动条 */
  .gameGrid::-webkit-scrollbar {
    display: none;
  }
  .gameGrid > button, .gameGrid > view {
    flex-shrink: 0;
  }
  
  .gameBtn {
    flex-shrink: 0; 
    margin-right: 30rpx;
    width: 450rpx !important;
    height: 400rpx;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    border: none;
    border-radius: 15rpx;
    position: relative;
    overflow: hidden;
    box-shadow: 0 12rpx 40rpx rgba(0,0,0,0.15);
  }
  .gameBtn text {
    position: absolute;
    bottom: 40rpx;
    left: 32rpx;
    color: #fff;
    font-size: 40rpx;
    font-weight: 600;
    text-shadow: 4rpx 4rpx 16rpx rgba(0,0,0,0.5);
  }

  .gameBtn:last-child {
    margin-right: 0;
  }

  .game-indicator-container {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 20rpx 10rpx;
    gap: 16rpx;
    margin-bottom: 0rpx;
  }
  .game-indicator-dot {
    width: 40rpx;
    height: 6rpx;
    border-radius: 6rpx;
    background: #ddd;           /* 灰色 */
    transition: all 0.3s;
    margin-bottom: 40rpx;
  }
  .game-indicator-dot.active {
    background: #333;           /* 黑色 */
    width: 60rpx;               /* 可稍宽一点 */
  }
/* #endregion */

  
