/* 全局基础 */
page {
  background: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

/* ---------- 欢迎横幅（不变） ---------- */
.welcome {
  background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('https://zhaoqiwangteaching-images.oss-cn-guangzhou.aliyuncs.com/hongkong1.jpg') center/cover no-repeat;
  padding: 80rpx 40rpx 120rpx;
  color: #fff;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-bottom: 80rpx;
}
.welcome .title {
  font-size: 48rpx;
  font-weight: 500;
  margin-bottom: 20rpx;
}
.welcome .desc {
  font-size: 28rpx;
  line-height: 1.6;
  margin-bottom: 40rpx;
}
.welcome .highlight {
  color: #25ff08;
}

.btn-group {
  margin-top: 100rpx;
  display: flex;
  flex-direction: column;   /* 改为纵向排列 */
  align-items: flex-start;  /* 左对齐，如需居中可改为 center */
  gap: 20rpx;               /* 两个按钮之间的间距 */
}

.btn {
  padding: 20rpx 30rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
  background: #111;
  color: #fff;
}
.btn.data {
  background: #fff;
  color: #111;
}

/* ---------- 横向滑动模块（新增） ---------- */
.module-slider {
  margin: 20rpx 0 40rpx;
  padding: 0 20rpx;
}
.module-header {
  padding: 10rpx 20rpx 20rpx;
}
.module-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #222;
}
.module-sub {
  font-size: 26rpx;
  color: #888;
  margin-left: 16rpx;
}

/* 横向滚动容器 */
.module-scroll {
  white-space: nowrap;
  padding: 10rpx 0 20rpx 20rpx;
  /* 隐藏滚动条 */
  scrollbar-width: none;
  -ms-overflow-style: none;
}
.module-scroll::-webkit-scrollbar {
  display: none;
}

/* 每张 Part 卡片（横向排列，宽度固定，高度自适应） */
.part-card {
  display: inline-block;
  width: 420rpx;
  margin-right: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  vertical-align: top;
  white-space: normal;   /* 内部文字换行 */
}
.part-card image {
  width: 100%;
  height: 200rpx;
}
.part-info {
  padding: 40rpx;
  overflow: hidden;   /* 防止内容溢出 */
}
.part-title {
  font-size: 30rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}
.part-desc {
  font-size: 24rpx;
  color: #555;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.pdf-btn {
  display: inline-block;
  padding: 16rpx 20rpx; 
  background: #fff;
  color: #111;
  border: 1rpx solid #ddd;
  border-radius: 20rpx;
  font-size: 24rpx;         /* 字号稍微缩小 */
  max-width: 100%;
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
/* #region ---------- 作业区域（分割图形） ---------- */
.welcomeHW {
  background: linear-gradient(rgba(0,0,0,0.1), rgba(0,0,0,0.1)), url('https://zhaoqiwangteaching-images.oss-cn-guangzhou.aliyuncs.com/hwWelcome.jpg') center/cover no-repeat;
  padding: 380rpx 40rpx 120rpx;
  color: #fff;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-bottom: 40rpx;
}
/* #endregion  */

/* #region ---------- 作业区域（横向滑动） ---------- */
.hw-section {
  padding: 40rpx 30rpx 20rpx;
  margin-bottom: 40rpx;
}
.section-title {
  font-size: 36rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 24rpx;
}

/* 横向滚动容器 */
.hw-scroll {
  white-space: nowrap;
  padding: 10rpx 0 20rpx 20rpx;
  scrollbar-width: none;
  -ms-overflow-style: none;
}
.hw-scroll::-webkit-scrollbar {
  display: none;
}

/* 每张作业卡片（改为高度自适应，由内容撑开） */
.hw-item {
  display: inline-block;
  width: 300rpx;               /* 卡片宽度，可根据需要调整 */
  margin-right: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;            /* 确保圆角裁剪图片 */
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  vertical-align: top;
  white-space: normal;
  padding-bottom: 20rpx;       /* 底部留一点空间 */
}

.hw-item image {
  margin-top: 5rpx;            /* 顶部留一点空间 */
  margin-left: auto;           /* 居中显示 */
  margin-right: auto;          /* 居中显示 */
  width: 85%;
  height: 300rpx;              /* 固定高度，让图片更大更饱满 */
  display: block;              /* 去除图片下方间隙 */
}

.hw-item text {
  font-size: 26rpx;
  display: block;
  text-align: center;
  margin: 16rpx 0 4rpx;        /* 调整文字与图片间距 */
  font-weight: 500;
}
/* #endregion */


/* ---------- 考试区域（不变） ---------- */
.exam-section {
  padding: 20rpx 30rpx 60rpx;
}
.exam-item {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}
.exam-item image {
  width: 40%;
  height: 240rpx;
}
.exam-info {
  flex: 1;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.exam-title {
  font-size: 34rpx;
  font-weight: 600;
}
.exam-desc {
  font-size: 26rpx;
  color: #555;
  margin: 16rpx 0 24rpx;
}
.exam-btn {
  align-self: flex-start;
  background: #000;
  color: #fff;
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

/* 响应式调整（作业和考试） */
@media (max-width: 750px) {
  .hw-grid { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 500px) {
  .hw-grid { grid-template-columns: repeat(2, 1fr); }
  .exam-item { flex-direction: column; }
  .exam-item image { width: 100%; height: 300rpx; }
}