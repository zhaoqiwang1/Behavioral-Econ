/* ===== 登录页 · 极简科技风 ===== */
/* 类名与结构完全不变，仅优化视觉 */

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
  background-color: #f8f9fc;  /* 柔和浅灰底 */
  box-sizing: border-box;
}

/* ---------- 登录按钮（未登录） ---------- */
.login-btn {
  width: 60%;
  max-width: 400rpx;
  padding: 28rpx 0;
  border: none;
  border-radius: 20rpx;
  background-color: #000;   /* 品牌蓝 */
  color: #fff;
  font-size: 34rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  box-shadow: 0 6rpx 20rpx rgba(229, 229, 229, 0.25);
  transition: opacity 0.2s, transform 0.1s;
}

.login-btn:active {
  opacity: 0.7;
  transform: scale(0.98);
}

/* ---------- 欢迎卡片（已登录） ---------- */
.welcome-section {
  width: 90%;
  max-width: 1000rpx;
  padding: 60rpx 40rpx 48rpx;
  background-color: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.welcome-text {
  font-size: 38rpx;
  font-weight: 600;
  color: #1c1e22;
  margin-bottom: 56rpx;
  text-align: center;
}

/* ---------- 按钮组（已登录） ---------- */
.logout-btn {
  width: 100%;
  padding: 24rpx 0;
  border: none;
  border-radius: 60rpx;
  font-size: 30rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  color: #fff;
  transition: opacity 0.2s, transform 0.1s;
  margin-bottom: 20rpx;          /* 按钮间距 */
}

.settings-btn {
  width: 100%;
  padding: 24rpx 0;
  border: none;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  color: #000;
  transition: opacity 0.2s, transform 0.1s;
  margin-bottom: 20rpx;          /* 按钮间距 */
}

.logout-btn:active,
.settings-btn:active {
  opacity: 0.7;
  transform: scale(0.98);
}

.logout-btn {
  background-color: #000;     /* 警示红 */
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(195, 195, 195, 0.2);
}

.settings-btn {
  background-color: #fff;     /* 与登录按钮统一 */
  box-shadow: 0 4rpx 16rpx rgba(89, 90, 90, 0.2);
  margin-bottom: 0;              /* 最后一个按钮去下边距 */
}