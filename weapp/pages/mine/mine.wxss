.container {
    padding: 40rpx;
    min-height: 100vh;
    background-color: #f5f5f5;
  }
  
  .login-btn {
    width: 60%;
    margin: 200rpx auto 0;
    background-color: #007aff;
    color: white;
    border-radius: 10rpx;
    font-size: 32rpx;
  }
  
  .welcome-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding-top: 200rpx;
  }
  
  .welcome-text {
    font-size: 36rpx;
    color: #333;
    margin-bottom: 80rpx;
  }
  
  .logout-btn {
    width: 60%;
    background-color: #ff3b30;
    color: white;
    border-radius: 10rpx;
    font-size: 32rpx;
  }