/* 全局样式 */
page {
    background: #f5f5f5;
    min-height: 100vh;
  }
  
  /* 未登录提示 */
  .login-prompt {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 80vh;
    padding: 0 30rpx;
  }
  
  .login-box {
    width: 100%;
    max-width: 600rpx;
    padding: 60rpx 40rpx;
    background: #fff;
    border-radius: 20rpx;
    box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
    text-align: center;
  }
  
  .login-box .title {
    display: block;
    font-size: 40rpx;
    font-weight: bold;
    color: #1a1a1a;
    margin-bottom: 20rpx;
  }
  
  .login-box .desc {
    display: block;
    font-size: 28rpx;
    color: #666;
    line-height: 1.6;
    margin-bottom: 40rpx;
  }
  
  .login-btn {
    width: 240rpx;
    height: 80rpx;
    line-height: 80rpx;
    background: #007bff;
    color: #fff;
    border-radius: 16rpx;
    font-size: 28rpx;
    font-weight: bold;
  }
  
  /* 已登录容器 */
  .mine-container {
    padding: 20px;
    background-color: #f5f5f5;
    height: 100vh;
  }
  
  /* 用户信息卡片 */
  .user-card {
    display: flex;
    align-items: center;
    padding: 40rpx 30rpx;
    background: #fff;
    border-radius: 20rpx;
    margin-bottom: 30rpx;
    box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  }
  
  .avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    margin-right: 20px;
    background: #f0f0f0;
  }
  
  .user-info {
    display: flex;
    align-items: center;
    margin-bottom: 20px;
  }
  
  .username {
    font-size: 20px;
    font-weight: bold;
  }
  
  .user-desc {
    font-size: 26rpx;
    color: #999;
  }
  
  /* 功能列表 */
  .menu-list {
    background: #fff;
    border-radius: 20rpx;
    overflow: hidden;
    box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
    margin-bottom: 40rpx;
  }
  
  .menu-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 30rpx;
    border-bottom: 1rpx solid #f0f0f0;
  }
  
  .menu-item:last-child {
    border-bottom: none;
  }
  
  .menu-text {
    font-size: 30rpx;
    color: #333;
  }
  
  .arrow {
    font-size: 32rpx;
    color: #ccc;
  }
  
  /* 退出登录 */
  .logout-box {
    text-align: center;
  }
  
  .logout-btn {
    width: 240rpx;
    height: 80rpx;
    line-height: 80rpx;
    background: #ff4d4f;
    color: #fff;
    border-radius: 16rpx;
    font-size: 28rpx;
    font-weight: bold;
  }

  .info-section {
    background-color: #ffffff;
    padding: 15px;
    border-radius: 10px;
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
  }

  .info-item {
    display: flex;
    justify-content: space-between;
    margin-bottom: 10px;
  }

  .label {
    font-weight: bold;
  }

  .value {
    color: #666;
  }