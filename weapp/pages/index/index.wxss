/* pages/index/index.wxss */
.welcomeContainer {
    position: relative;
    width: 100%;
    margin: 0;
    padding: 0;
    /* 关键：向左拉满屏幕，去掉左右空白 */
    margin-left: calc(-50vw + 50%);
    margin-top: calc(-50vw + 50%);
    width: 100vw;
  }
  
  /* 背景图：铺满、无空白 */
  .welcomeBg {
    width: 100%;
    height: 500rpx;
    object-fit: cover;
    display: block;
    margin: 0;
    padding: 0; 
    border-radius: 0 !important;
  }
  
  /* 文字层 */
  .welcomeContent {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background: rgba(0, 0, 0, 0.3);
    color: white;
    text-align: center;
    padding: 0 30rpx;
    box-sizing: border-box;
  }
  
  .welcomeMessageTitle {
    font-size: 44rpx;
    color: #f5f5f5;
    font-weight: 500;
  }
  
  .welcomeMessageDescription {
    font-size: 28rpx;
    color: #81da76;
    line-height: 1.6;
  }
  
  .welcomeMessageHightlight {
    color: #dbfbe0;
  }

.container {
    padding: 20rpx;
    background: #fff;
  }
  
  .welcome {
    text-align: center;
    padding: 40rpx 0;
  }
  
  .title {
    font-size: 44rpx;
    font-weight: bold;
    color: #1a1a1a;
  }
  
  .desc {
    font-size: 26rpx;
    color: #666;
    margin-top: 16rpx;
    line-height: 1.6;
  }
  
  .highlight {
    color: #1677ff;
    font-weight: bold;
  }
  
  /* 行为经济学 */
  .section {
    margin-bottom: 60rpx;
  }
  
  .behav {
    display: flex;
    flex-direction: row;
  }
  
  .logic {
    display: flex;
    flex-direction: row;
  }
  
  .left, .right {
    flex: 1;
    padding: 20rpx;
  }
  
  image {
    width: 100%;
    border-radius: 12rpx;
    margin-bottom: 16rpx;
  }
  
  .courseTitle {
    font-size: 38rpx;
    font-weight: bold;
    margin-bottom: 20rpx;
    color: #222;
  }
  
  .sectionTitle {
    font-size: 28rpx;
    font-weight: bold;
    margin-bottom: 12rpx;
  }
  
  .text {
    font-size: 26rpx;
    color: #555;
    line-height: 1.6;
    margin-bottom: 20rpx;
  }
  
  .item {
    margin-bottom: 20rpx;
  }
  
  .itemTitle {
    font-size: 28rpx;
    font-weight: bold;
    color: #333;
  }
  
  .itemText {
    font-size: 25rpx;
    color: #666;
    line-height: 1.5;
  }
  
  .btn {
    background: #1677ff;
    color: white;
    border-radius: 8rpx;
    font-size: 28rpx;
    padding: 16rpx 32rpx;
    margin-top: 20rpx;
  }
  
  /* R语言 */
  .rlang {
    text-align: center;
  }
  
  .rbtn {
    background: #f5f5f5;
    border: 2rpx solid #1677ff;
    padding: 30rpx;
  }
  
  .rTitle {
    font-size: 36rpx;
    color: #1677ff;
    font-weight: bold;
  }