/* #region 主页欢迎界面 */
.welcomeContainer {
    position: relative;
    width: 100%;
    margin: 0;
    padding: 0;
    /* 关键：向左拉满屏幕，去掉左右空白 */
    margin-left: calc(-50vw + 50%);
    margin-top: calc(-50vw + 50%);
    width: 100vw;
  }
  
  /* 背景图：铺满、无空白 */
  .welcomeBg {
    width: 100%;
    height: 500rpx;
    object-fit: cover;
    display: block;
    margin: 0;
    padding: 0; 
    border-radius: 0 !important;
  }
  
  /* 文字层 */
  .welcomeContent {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background: rgba(0, 0, 0, 0.3);
    color: white;
    text-align: center;
    padding: 0 30rpx;
    box-sizing: border-box;
  }
  
  .welcomeMessageTitle {
    font-size: 44rpx;
    color: #f5f5f5;
    font-weight: 500;
  }
  
  .welcomeMessageDescription {
    font-size: 28rpx;
    color: #81da76;
    line-height: 1.6;
  }
  
  .welcomeMessageHightlight {
    color: #dbfbe0;
  }

.container {
    padding: 0;
    background: #fff;
  }
  
  .welcome {
    text-align: center;
    padding: 40rpx 0;
  }
  
  .title {
    font-size: 44rpx;
    font-weight: bold;
    color: #1a1a1a;
  }
  
  .desc {
    font-size: 26rpx;
    color: #666;
    margin-top: 16rpx;
    line-height: 1.6;
  }
  
  .highlight {
    color: #1677ff;
    font-weight: bold;
  }
  /* #endregion */


  /* #region 行为经济学 */
  /* 图片渐变透明效果（小程序适配版） */
.behavSciCourseImage .course-img {
    width: 100%;
    height: auto;
    mask-image: 
      linear-gradient(to bottom, rgba(0,0,0,1) 80%, rgba(0,0,0,0) 100%),
      linear-gradient(to top, rgb(162, 162, 162,1) 70%, rgba(245,245,245,0) 100%);
    -webkit-mask-image: 
      linear-gradient(to bottom, rgba(0,0,0,1) 80%, rgba(0,0,0,0) 100%),
      linear-gradient(to top, rgb(162, 162, 162,1) 70%, rgba(245,245,245,0) 100%);
  }
  
  .behavSciCourseSection {
    background-color: rgb(239, 239, 239);
    padding-bottom: 100rpx;
  }
  
  .behavSciCourseIntro {
    background-color: rgb(239, 239, 239);
    display: flex;
    flex-direction: column;
    padding-top: 50rpx;
    padding-bottom: 50rpx;
  }
  
  .courseBehavSciTitle {
    font-size: 46rpx;
    font-weight: 600;
    text-align: center;
    padding-left: 10%;
    padding-right: 10%;
    padding-top: 10rpx;
  }
  
  .behavSciCourseIntroTitle {
    padding-left: 10%;
    padding-right: 10%;
    padding-top: 10rpx;
    padding-bottom: 30rpx;
  }
  
  .behavSciCourseIntroTitle .title {
    font-size: 36rpx;
    font-weight: bold;
    margin-bottom: 10rpx;
  }
  
  .behavSciCourseIntroTitle .desc {
    font-size: 28rpx;
    color: #333;
    line-height: 1.6;
  }
  
  /* 四个项目布局 */
  .behavSciCourseItems {
    display: flex;
    flex-wrap: wrap;
    /* 左右间距，上下间距 */
    column-gap: 6%;
    row-gap: 40rpx;
    padding-left: 10%;
    padding-right: 10%;
    padding-top: 30rpx;
    padding-bottom: 30rpx;
  }
  
  .behavSciCourseIntroItem {
    /* 每列宽度：(100% - 6%间距) / 2 = 47%，完美平分 */
    width: 47%;
    flex: none;
  }
  
  .behavSciCourseItemTitle {
    font-size: 32rpx;
    font-weight: bold;
    margin-bottom: 10rpx;
  }
  
  .behavSciCourseItemDescription {
    font-size: 28rpx;
    color: #666;
    line-height: 1.6;
  }
  
  /* 按钮 */
  .behavSciCourseBtnPosition {
    margin-top: 40rpx;
    padding-left: 10%;
  }
  
  .BtnBehavSci {
    width: 220rpx;
    height: 80rpx;
    line-height: 80rpx;
    background: #000;
    color: #fff;
    border-radius: 8rpx;
    font-size: 28rpx;
  }
/* #endregion */

  /* #region R语言 */
  .rlang {
    text-align: center;
  }
  
  .rbtn {
    background: #f5f5f5;
    border: 2rpx solid #1677ff;
    padding: 30rpx;
  }
  
  .rTitle {
    font-size: 36rpx;
    color: #1677ff;
    font-weight: bold;
  }
  /* #endregion */

   /* #region 逻辑学 */
.logicCourseSection {
    background-color: #000000;
    display: flex;
    flex-direction: column; /* 上下布局，实现全局居中 */
    align-items: center; /* 所有子元素水平居中 */
    padding: 60rpx 0;
    overflow: hidden;
  }
  
  /* 标题：整个页面正中间 */
  .courseLogicTitle {
    color: #fff;
    font-size: 46rpx;
    font-weight: 600;
    text-align: center;
    margin-bottom: 40rpx;
    width: 100%;
  }
  
  /* 内容包裹层：文字 + 图片左右排列 */
  .logicContentWrapper {
    display: flex;
    flex-direction: row;
    align-items: center;
    width: 90%; /* 控制整体宽度，避免贴边 */
    gap: 40rpx;
    margin-bottom: 40rpx;
  }
  
  /* 左侧文字区域 */
  .logicCourseIntro {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  
  /* 每个逻辑模块 */
  .logicCourseIntroItem {
    margin-bottom: 30rpx;
  }
  
  .logicCourseIntroTitle {
    color: #fff;
    font-size: 32rpx;
    font-weight: 500;
    margin-bottom: 8rpx;
  }
  
  .logicCourseIntroDescription {
    color: #a1a1a1;
    font-size: 26rpx;
    line-height: 1.6;
  }
  
  /* 右侧两张图片 */
  .logicCourseImages {
    width: 320rpx;
    display: flex;
    flex-direction: column;
    gap: 6rem;
  }
  
  .logic-img {
    width: 100%;
    height: auto;
    mask-image:
      linear-gradient(to bottom, rgba(0,0,0,1) 60%, rgba(0,0,0,0) 100%),
      linear-gradient(to left, rgba(0,0,0,1) 60%, rgba(0,0,0,0) 100%);
    -webkit-mask-image:
      linear-gradient(to bottom, rgba(0,0,0,1) 60%, rgba(0,0,0,0) 100%),
      linear-gradient(to left, rgba(0,0,0,1) 60%, rgba(0,0,0,0) 100%);
    mask-composite: intersect;
    -webkit-mask-composite: source-in;
  }
  
  /* 按钮：整个页面正中间 */
  .logicCourseBtnPosition {
    width: 100%;
    display: flex;
    justify-content: center;
  }
  
  .BtnLogic {
    background-color: #fff;
    color: #000;
    font-size: 28rpx;
    padding: 0 60rpx;
    line-height: 80rpx;
    border-radius: 8rpx;
  }
    /* #endregion */

/* #region 结束图片 */
/* ===================== 底部结束界面 ===================== */
.endContainer {
    position: relative;
    width: 100%;
    margin: 0;
    padding: 0;
    margin-left: calc(-50vw + 50%);
    width: 100vw;
    min-height: 800rpx; /* 高度你可以自己调 */
  }
  
  .endBg {
    width: 100%;
    height: 800rpx; /* 跟上面高度保持一致 */
    object-fit: cover;
    display: block;
    margin: 0;
    padding: 0;
    border-radius: 0 !important;
  }
/* #endregion */