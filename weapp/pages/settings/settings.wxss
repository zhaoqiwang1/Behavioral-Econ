.container {
    min-height: 100vh;
    background: #f5f5f5;
    padding: 40rpx;
    box-sizing: border-box;
  }
  
  .settings-card {
    background: white;
    border-radius: 20rpx;
    padding: 40rpx 30rpx;
    box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  }
  
  .header {
    text-align: center;
    margin-bottom: 40rpx;
  }
  
  .title {
    font-size: 40rpx;
    font-weight: bold;
    color: #333;
  }
  
  /* 查看模式 */
  .view-mode .info-group {
    margin-bottom: 30rpx;
  }
  
  .info-row {
    display: flex;
    justify-content: space-between;
    padding: 20rpx 0;
    border-bottom: 1px solid #f0f0f0;
  }
  
  .label {
    color: #666;
    font-size: 30rpx;
  }
  
  .value {
    color: #333;
    font-size: 30rpx;
    font-weight: 500;
  }
  
  /* 编辑模式 */
  .edit-group {
    margin-bottom: 30rpx;
  }
  
  .edit-row {
    display: flex;
    align-items: center;
    margin-bottom: 24rpx;
  }
  
  .edit-label {
    width: 120rpx;
    font-size: 30rpx;
    color: #333;
    flex-shrink: 0;
  }
  
  .edit-input {
    flex: 1;
    height: 76rpx;
    border: 1px solid #ddd;
    border-radius: 12rpx;
    padding: 0 20rpx;
    font-size: 28rpx;
    background: #fafafa;
  }
  
  .picker-display {
    flex: 1;
    height: 76rpx;
    border: 1px solid #ddd;
    border-radius: 12rpx;
    padding: 0 20rpx;
    font-size: 28rpx;
    line-height: 76rpx;
    background: #fafafa;
    color: #333;
  }
  
  /* 按钮组 */
  .button-group {
    display: flex;
    justify-content: space-between;
    margin-top: 40rpx;
    gap: 20rpx;
  }
  
  .btn {
    flex: 1;
    height: 80rpx;
    border-radius: 40rpx;
    font-size: 30rpx;
    font-weight: 500;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .btn-back {
    background: #f0f0f0;
    color: #666;
  }
  
  .btn-edit {
    background: #007aff;
    color: white;
  }
  
  .btn-cancel {
    background: #f0f0f0;
    color: #666;
  }
  
  .btn-submit {
    background: #007aff;
    color: white;
  }
  
  .btn-submit[disabled] {
    opacity: 0.6;
  }